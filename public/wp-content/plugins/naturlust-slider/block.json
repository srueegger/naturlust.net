{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "naturlust/tagebuch-slider",
	"version": "1.0.0",
	"title": "Tagebuch-Slider",
	"category": "media",
	"icon": "images-alt2",
	"description": "Slider mit den neuesten Beiträgen einer Kategorie (Standard: Tagebuch) – Beitragsbild als Slide, mit Titel und Datum, verlinkt auf den Beitrag.",
	"textdomain": "naturlust-slider",
	"keywords": ["slider", "karussell", "tagebuch", "beiträge"],
	"supports": {
		"html": false,
		"align": ["wide", "full"],
		"spacing": { "margin": true }
	},
	"attributes": {
		"category": { "type": "string", "default": "tagebuch" },
		"count": { "type": "number", "default": 4 }
	},
	"render": "file:./render.php",
	"viewScript": "naturlust-slider-view",
	"style": "naturlust-slider-style"
}
